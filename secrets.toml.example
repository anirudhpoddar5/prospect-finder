# Paste this into Streamlit Cloud → Settings → Secrets
# Or create a local .streamlit/secrets.toml for development

[secrets]
password = "your-team-password"

# At least one of these:
google_api_key = "AIzaSy..."         # Google Places API (free $200/mo credit)
geoapify_key = "YOUR_GEOAPIFY_KEY"   # Geoapify Places API (3000 calls/day free)

# Optional: Google Custom Search (100 queries/day free)
# 1. Enable Custom Search API in Google Cloud Console
# 2. Create a search engine at https://programmablesearchengine.google.com/
# 3. Copy the Search engine ID (cx) here:
google_cx = "YOUR_SEARCH_ENGINE_ID"
